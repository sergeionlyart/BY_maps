[
 {
  "start": 0.3,
  "end": 6.2,
  "lines": [
   "Что мы видим из космоса ночью — население,",
   "экономику или только свет?"
  ],
  "spokenScene": 1
 },
 {
  "start": 6.4,
  "end": 8.81,
  "lines": [
   "Спутник не считает людей."
  ],
  "spokenScene": 2
 },
 {
  "start": 8.81,
  "end": 14.0,
  "lines": [
   "Ночные огни — не ответ, а независимый след",
   "активности."
  ],
  "spokenScene": 2
 },
 {
  "start": 14.2,
  "end": 18.3,
  "lines": [
   "В 1990-е световой след Беларуси сокращается."
  ],
  "spokenScene": 3
 },
 {
  "start": 18.3,
  "end": 22.22,
  "lines": [
   "В 2000-е всё заметнее Минская агломерация."
  ],
  "spokenScene": 3
 },
 {
  "start": 22.22,
  "end": 26.6,
  "lines": [
   "Промышленный объект — очаг, агломерация —",
   "сеть."
  ],
  "spokenScene": 3
 },
 {
  "start": 28.3,
  "end": 35.45,
  "lines": [
   "Где свет расходится со статистикой — главный",
   "сигнал для дополнительного исследования:"
  ],
  "spokenScene": 4
 },
 {
  "start": 35.45,
  "end": 37.56,
  "lines": [
   "здесь что-то не сходится."
  ],
  "spokenScene": 4
 },
 {
  "start": 37.56,
  "end": 40.5,
  "lines": [
   "Расхождение не доказывает проблему."
  ],
  "spokenScene": 4
 },
 {
  "start": 40.7,
  "end": 41.94,
  "lines": [
   "Три кандидата:"
  ],
  "spokenScene": 5
 },
 {
  "start": 41.94,
  "end": 46.18,
  "lines": [
   "Минская агломерация светится сильнее",
   "демографии;"
  ],
  "spokenScene": 5
 },
 {
  "start": 46.18,
  "end": 49.19,
  "lines": [
   "Смолевичи и Жодино — свет отстаёт;"
  ],
  "spokenScene": 5
 },
 {
  "start": 49.19,
  "end": 51.75,
  "lines": [
   "Островец растёт ярче жителей."
  ],
  "spokenScene": 5
 },
 {
  "start": 52.3,
  "end": 54.63,
  "lines": [
   "После 2024 года — модель."
  ],
  "spokenScene": 6
 },
 {
  "start": 54.63,
  "end": 60.4,
  "lines": [
   "Население сокращается во всех сценариях,",
   "сильнее на периферии."
  ],
  "spokenScene": 6
 },
 {
  "start": 60.6,
  "end": 65.05,
  "lines": [
   "Откройте карту и проверьте гипотезы вместе с",
   "нами."
  ],
  "spokenScene": 7
 }
]
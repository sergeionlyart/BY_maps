[
 {
  "start": 0.3,
  "end": 4.8,
  "lines": [
   "Что мы видим из космоса ночью — население,",
   "экономику или только свет?"
  ],
  "spokenScene": 1
 },
 {
  "start": 5.3,
  "end": 7.25,
  "lines": [
   "Спутник не считает людей и не измеряет выпуск."
  ],
  "spokenScene": 2
 },
 {
  "start": 7.25,
  "end": 9.51,
  "lines": [
   "Он фиксирует свет жилья, дорог, услуг и",
   "производства."
  ],
  "spokenScene": 2
 },
 {
  "start": 9.51,
  "end": 11.8,
  "lines": [
   "Ночные огни — не ответ, а независимый след",
   "активности."
  ],
  "spokenScene": 2
 },
 {
  "start": 12.3,
  "end": 16.76,
  "lines": [
   "В 1990-е световой след Беларуси сокращается."
  ],
  "spokenScene": 3
 },
 {
  "start": 16.76,
  "end": 21.01,
  "lines": [
   "В 2000-е всё заметнее Минская агломерация."
  ],
  "spokenScene": 3
 },
 {
  "start": 21.01,
  "end": 27.8,
  "lines": [
   "Промышленный объект выглядит локальным очагом,",
   "агломерация — сетью."
  ],
  "spokenScene": 3
 },
 {
  "start": 28.3,
  "end": 29.87,
  "lines": [
   "Главная ценность спутниковых наблюдений — там,"
  ],
  "spokenScene": 4
 },
 {
  "start": 29.87,
  "end": 31.81,
  "lines": [
   "где свет расходится со статистикой населения и",
   "экономики."
  ],
  "spokenScene": 4
 },
 {
  "start": 31.81,
  "end": 34.48,
  "lines": [
   "Это главный сигнал для дополнительного",
   "исследования: здесь что-то не сходится."
  ],
  "spokenScene": 4
 },
 {
  "start": 34.48,
  "end": 37.62,
  "lines": [
   "Возможно, источники описывают разные процессы;",
   "возможно, привычного объяснения недостаточно."
  ],
  "spokenScene": 4
 },
 {
  "start": 37.62,
  "end": 39.8,
  "lines": [
   "Расхождение не доказывает проблему, но",
   "указывает, где её искать."
  ],
  "spokenScene": 4
 },
 {
  "start": 40.3,
  "end": 41.5,
  "lines": [
   "Три кандидата:"
  ],
  "spokenScene": 5
 },
 {
  "start": 41.5,
  "end": 44.54,
  "lines": [
   "Минская агломерация светится сильнее своей",
   "демографической динамики;"
  ],
  "spokenScene": 5
 },
 {
  "start": 44.54,
  "end": 46.91,
  "lines": [
   "в зоне Смолевичей и Жодино свет отстаёт от",
   "населения;"
  ],
  "spokenScene": 5
 },
 {
  "start": 46.91,
  "end": 48.7,
  "lines": [
   "Островец растёт ярче, чем число жителей."
  ],
  "spokenScene": 5
 },
 {
  "start": 48.7,
  "end": 51.8,
  "lines": [
   "Мы проверим производство, занятость, миграцию,",
   "энергопотребление и инфраструктуру."
  ],
  "spokenScene": 5
 },
 {
  "start": 52.3,
  "end": 53.66,
  "lines": [
   "После 2024 года — модель."
  ],
  "spokenScene": 6
 },
 {
  "start": 53.66,
  "end": 57.05,
  "lines": [
   "Во всех сценариях население сокращается,",
   "сильнее на периферии."
  ],
  "spokenScene": 6
 },
 {
  "start": 57.05,
  "end": 61.8,
  "lines": [
   "В демонстрации эффект усилен: слабые огни",
   "гаснут, агломерации остаются островами света."
  ],
  "spokenScene": 6
 },
 {
  "start": 62.2,
  "end": 64.8,
  "lines": [
   "Откройте карту и проверьте гипотезы вместе с",
   "нами."
  ],
  "spokenScene": 7
 }
]
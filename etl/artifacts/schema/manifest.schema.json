{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "by-maps-artifact-manifest-1.0",
  "title": "Манифест проверяемого пакета артефактов (ARTIFACT_STANDARD.md v1.0)",
  "type": "object",
  "required": [
    "schema_version", "id", "title", "version", "released", "git_tag",
    "landing_url", "authors", "files", "sources", "entrypoints",
    "environment", "expected_results", "limitations_file", "agent_instructions"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "released": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "git_tag": { "type": "string", "pattern": "^artifact-[a-z0-9-]+-v\\d+\\.\\d+\\.\\d+$" },
    "landing_url": { "type": "string", "format": "uri" },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "role"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "role": { "enum": ["raw", "intermediate", "final", "code", "params", "docs", "checks"] },
          "license": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "url", "accessed"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "vendored": { "type": "string" },
          "fetch": { "type": "string" },
          "license": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "required": ["reproduce"],
      "properties": {
        "reproduce": { "type": "string" },
        "verify": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "required": ["python", "lock"],
      "properties": {
        "python": { "type": "string" },
        "lock": { "type": "string" },
        "seed": { "type": ["integer", "null"] }
      }
    },
    "expected_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["metric", "value", "tolerance", "description"],
        "properties": {
          "metric": { "type": "string" },
          "value": { "type": "number" },
          "tolerance": { "type": "number", "minimum": 0 },
          "description": { "type": "string" }
        }
      }
    },
    "limitations_file": { "const": "LIMITATIONS.md" },
    "agent_instructions": { "const": "AGENT.md" }
  }
}
